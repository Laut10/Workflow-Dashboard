generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks Task[]
}

model Task {
  id         String    @id @default(cuid())
  name       String
  type       String
  status     String    @default("pending")
  order      Int
  config     String
  result     String?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  workflowId String
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  logs Log[]
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
